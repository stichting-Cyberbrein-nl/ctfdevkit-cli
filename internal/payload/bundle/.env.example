APP_NAME="CTF:DevKit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://ctf.dev

DEVKIT_BRAND=Cyberbrein
DEVKIT_VERSION={{VERSION}}
DEVKIT_BIND_IP=127.0.0.1

LOG_CHANNEL=stack
